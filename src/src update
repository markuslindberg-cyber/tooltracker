          <Tabs value={itemType} onValueChange={setItemType} className="w-full">
            <TabsList className="grid w-full grid-cols-2">
              <TabsTrigger value="tools">Maskiner</TabsTrigger>
              <TabsTrigger value="handtools">Handredskap</TabsTrigger>
            </TabsList>
