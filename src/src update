                {statusOptions.map(opt => (
                  <FilterOption 
                    key={opt.value} 
                    label={opt.label} 
                    selected={statusFilter.includes(opt.value)} 
                    onClick={() => {
                      const newFilter = statusFilter.includes(opt.value)
                        ? statusFilter.filter(v => v !== opt.value)
                        : [...statusFilter, opt.value];
                      onStatusChange(newFilter);
                    }} 
                  />
                ))}
