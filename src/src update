        {/* Scan log */}
        {scanLog.length > 0 && (
          <div className="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 p-6 shadow-sm">
            <h2 className="text-lg font-semibold mb-4 flex items-center gap-2 dark:text-gray-100">
