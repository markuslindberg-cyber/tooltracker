            >
              <List className="w-4 h-4" />
            </Button>
            {viewModes?.includes('grouped') && (
              <Button
                variant={viewMode === 'grouped' ? 'default' : 'ghost'}
                size="icon"
                onClick={() => onViewModeChange('grouped')}
                className={`h-9 w-9 rounded-none ${viewMode === 'grouped' ? 'bg-[#8B1E1E] hover:bg-[#6B1515]' : ''}`}
