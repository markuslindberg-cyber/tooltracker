              </div>
            </div>
          )}

          {scannerActive && (
            <div className="space-y-4">
              <div id="barcode-scanner" className="rounded-xl overflow-hidden" />
              <Button onClick={() => setScannerActive(false)} variant="outline" className="w-full">Avbryt kameraskanning</Button>
