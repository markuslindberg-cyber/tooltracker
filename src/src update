          </Button>
          <Button size="sm" onClick={() => setShowBatchModal(true)} className="bg-[#8B1E1E] hover:bg-[#6B1515] gap-2">
            <Plus className="w-4 h-4" /><span className="hidden sm:inline">Lägg till redskap</span>
