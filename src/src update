                           size="sm"
                           onClick={() => setStep(3) || setSelectedRequest(request)}
                           className="mt-3 w-full bg-blue-600 hover:bg-blue-700"
                         >
                           → Gå till uttag
                         </Button>
                       )}
                       </div>
                       )}
                       </div>
                       ))}
                       </div>
                       </div>
                       </div>
                       )}
                       </>
                       )}

