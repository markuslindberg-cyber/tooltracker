        purchase_location: r.purchase_location || '',
        invoice_number: r.invoice_number || '',
        service_cost: parseFloat(r.service_cost) || 0,
        assigned_to_name: r.assigned_to_name || '',
        notes: r.notes || '',
        matchedTool: matched || null,
        action: matched ? 'update' : 'create',
