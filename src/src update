                      onClick={() => {
                        if (!Array.isArray(categoryFilter)) { onCategoryChange(cat); return; }
                        onCategoryChange(categoryFilter.includes(cat) ? categoryFilter.filter(v => v !== cat) : [...categoryFilter, cat]);
