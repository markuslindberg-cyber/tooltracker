                ))
              )}
            </div>
          </div>
        </div>
        </div>

        <DialogFooter className="mt-6">
          <Button variant="outline" onClick={() => onOpenChange(false)}>
            Stäng
          </Button>
          <Button
            onClick={handleSave}
            disabled={loading || createMutation.isPending}
            className="bg-[#8B1E1E] hover:bg-[#6B1515]"
