                            {new Date(report.checked_out_date).toLocaleString('sv-SE')}
                          </p>
                        </div>
                      </div>

                      {/* Artikellista */}
                      <div>
                        <p className="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wide mb-2">
                          Uttagna artiklar ({report.checked_out_items.length} st)
