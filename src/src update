                <span className="text-xs text-gray-400">({grouped[key].length})</span>
              </div>
              <div className="space-y-3">
                {grouped[key].map(report => (
                  <ReportCard key={report.id} report={report} isAdmin={isAdmin} onDelete={handleDelete} />
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
